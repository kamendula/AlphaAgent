# AlphaAgent environment — copy to .env and fill in ONLY the keys you have.
# The demo path (`make demo`) needs none of these.
# Free providers (yfinance, CoinGecko) require no key.

# --- LLM providers (needed once the agent layer lands in M1) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Optional paid market-data providers (future) ---
# FMP_API_KEY=
# ALPHAVANTAGE_API_KEY=
